# OpenAI API key (used for CRM entity extraction; also for Whisper when
# WHISPER_BACKEND=openai, which is the default)
OPENAI_API_KEY=sk-...

# Anthropic API key (used ONLY for Claude-powered topic-shift detection)
ANTHROPIC_API_KEY=sk-ant-...

# Salesforce credentials
SF_USERNAME=you@example.com
SF_PASSWORD=your-password
SF_SECURITY_TOKEN=your-security-token
# Use "login" for production orgs or "test" for sandboxes
SF_DOMAIN=login

# Server settings (optional)
HOST=127.0.0.1
PORT=8000

# Audio capture settings (optional)
# Length of each audio chunk sent to Whisper, in seconds
AUDIO_CHUNK_SECONDS=5
# Microphone sample rate
AUDIO_SAMPLE_RATE=16000

# ---------------------------------------------------------------------------
# Transcription backend (optional — defaults to "openai")
# ---------------------------------------------------------------------------
# Set to "local" to run Whisper entirely on-device with faster-whisper.
# No audio data leaves your machine when using the local backend.
# Requires:  pip install faster-whisper
#
# WHISPER_BACKEND=openai

# Model size for the local backend.
# Options: tiny | base | small | medium | large-v2 | large-v3
# Larger models are more accurate but slower and use more RAM.
# "base" is a good starting point for most laptops (CPU inference).
#
# LOCAL_WHISPER_MODEL=base

# Device for the local backend: "cpu" (default) or "cuda" (NVIDIA GPU).
#
# LOCAL_WHISPER_DEVICE=cpu

# Compute type for faster-whisper quantisation.
# "int8" (default) is best for CPU. Use "float16" for GPU.
#
# LOCAL_WHISPER_COMPUTE_TYPE=int8
